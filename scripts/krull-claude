#!/bin/bash
# Auto-accept tool prompts when running in --print/-p mode. In interactive
# mode Claude Code shows the user a permission prompt for every tool call
# and the user can click through, but in --print mode any unanswered prompt
# blocks the run forever. The lang_docs filter (proxy/sse_patch.py) teaches
# the model to query the offline Kiwix devdocs via `curl localhost:8090`,
# which would be silently blocked in --print mode without this. Interactive
# sessions are unaffected — the prompts still appear there.
PRINT_MODE=0
for arg in "$@"; do
  case "$arg" in
    -p|--print) PRINT_MODE=1; break ;;
  esac
done

EXTRA=()
if [ "$PRINT_MODE" -eq 1 ]; then
  EXTRA+=(--permission-mode acceptEdits)
fi

# Generate a session ID so proxy logs can be correlated with this
# invocation. Written to a known file the proxy reads (it has $HOME
# mounted read-only). Also exported so hooks/scripts can reference it.
export KRULL_SESSION_ID="$(date +%Y%m%dT%H%M%S)-$$"
KRULL_SESSION_FILE="$HOME/.krull-session"
echo "$KRULL_SESSION_ID" > "$KRULL_SESSION_FILE"
echo "krull-claude session: $KRULL_SESSION_ID"
echo "  logs: tail -f logs/proxy.jsonl | grep $KRULL_SESSION_ID"

# Clean up the session file on exit
cleanup() { rm -f "$KRULL_SESSION_FILE"; }
trap cleanup EXIT

# Tell Claude Code the real context window size so its auto-compactor
# fires at the right threshold. Without this, Claude Code assumes 200K
# (the real claude-sonnet-4-6 window) but the backend is qwen 9B with
# 131K. Claude Code's compaction threshold = window - 20K - 13K, so
# with 131072 it fires at ~98K tokens instead of the default ~167K.
ANTHROPIC_AUTH_TOKEN=sk-local-dev-key \
ANTHROPIC_BASE_URL=http://localhost:4000 \
CLAUDE_CODE_AUTO_COMPACT_WINDOW=${CLAUDE_CODE_AUTO_COMPACT_WINDOW:-131072} \
DISABLE_TELEMETRY=1 \
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1 \
exec claude "${EXTRA[@]}" "$@"
