#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/scripts"

usage() {
    echo "Usage: ./krull <command> [args]"
    echo ""
    echo "Commands:"
    echo "  start                    Check deps, pull images (first run), start all services"
    echo "  stop                     Stop all services (data preserved)"
    echo "  setup                    Provision filters, install krull-claude (run once)"
    echo "  update                   Pull latest images and recreate containers"
    echo "  pull-model <model ...>   Pull Ollama models with tuned parameters"
    echo "  download-wikipedia <pkg> Download Wikipedia ZIM files (mini|nopic|medicine|full)"
    echo "  download-knowledge <pkg> Download dev docs, Stack Exchange, and more"
    echo "  download-maps <region>   Download OpenStreetMap tiles for offline maps"
    echo ""
    echo "Examples:"
    echo "  ./krull start"
    echo "  ./krull pull-model frob/qwen3.5-instruct:9b"
    echo "  ./krull download-wikipedia medicine"
    echo "  ./krull download-knowledge dev-essentials"
    echo "  ./krull download-maps oregon"
}

if [ $# -eq 0 ] || [ "$1" = "help" ] || [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
    usage
    exit 0
fi

COMMAND="$1"
shift

SCRIPT="$SCRIPT_DIR/$COMMAND.sh"

if [ ! -f "$SCRIPT" ]; then
    echo "Error: unknown command '$COMMAND'"
    echo ""
    usage
    exit 1
fi

exec "$SCRIPT" "$@"
