# Persistent data (models, WebUI config, chat history)
data/ollama/*
data/webui/*
!data/ollama/.gitkeep
!data/webui/.gitkeep
data/mbtiles/*
data/tiles/*
data/photon/*
!data/mbtiles/.gitkeep
!data/tiles/.gitkeep
!data/photon/.gitkeep

# Environment (generated by start.sh — contains COMPOSE_FILE for GPU detection)
.env

# SearXNG config (generated at startup, container writes as different UID)
searxng/

# ZIM files (large offline knowledge archives)
zim/*.zim
# HEAD-probe sidecars left next to partial downloads
zim/*.meta

# Download tracker runtime state (live-updating; never commit)
data/downloads/

# Map viewer build artifacts
map-viewer/node_modules/
map-viewer/dist/
map-viewer/*.bak

# Legacy map viewer assets (replaced by Vite build)
map-viewer/lib/
map-viewer/fonts/
map-viewer/style-*.json

# Local binaries (pmtiles CLI, etc.)
.local/

# Playwright MCP (browser automation state)
.playwright-mcp/

# Claude Code local config and skills (user-specific)
.claude/
CLAUDE.md

# Python bytecode caches
__pycache__/
*.pyc
