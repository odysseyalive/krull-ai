# Persistent data (models, WebUI config, chat history)
data/ollama/*
data/webui/*
!data/ollama/.gitkeep
!data/webui/.gitkeep
data/mbtiles/*
data/tiles/*
data/photon/*
!data/mbtiles/.gitkeep
!data/tiles/.gitkeep
!data/photon/.gitkeep

# Environment (generated by start.sh — contains COMPOSE_FILE for GPU detection)
.env

# SearXNG config (generated at startup, container writes as different UID)
searxng/

# ZIM files (large offline knowledge archives)
zim/*.zim
# HEAD-probe sidecars left next to partial downloads
zim/*.meta

# Download tracker runtime state (live-updating; never commit)
data/downloads/

# Runtime state files tracked by mistake in earlier commits — untracked
# with `git rm --cached` but kept on disk so the running stack keeps
# writing its normal state.
data/.install-log
data/.setup-complete
data/.update-log
data/.update-status

# Local work data — not part of the distribution
data/aero-work/

# Dev scratch at repo root: ad-hoc screenshots and playwright snapshot
# dumps. Anchored to the repo root so app assets like
# kiwix-front/favicon/*.png and map-viewer/public/sprites/*.png are
# unaffected.
/*.png
/lib-snap.yml

# Map viewer build artifacts
map-viewer/node_modules/
map-viewer/dist/
map-viewer/*.bak

# Legacy map viewer assets (replaced by Vite build)
map-viewer/lib/
map-viewer/fonts/
map-viewer/style-*.json

# Local binaries (pmtiles CLI, etc.)
.local/

# Playwright MCP (browser automation state)
.playwright-mcp/

# Claude Code local config and skills (user-specific)
.claude/
CLAUDE.md

# Proxy session logs (written by sse_patch.py)
logs/

# Python bytecode caches
__pycache__/
*.pyc
