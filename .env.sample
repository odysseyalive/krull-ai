# Krull AI Environment Configuration
# Copy this file to .env and adjust as needed.
# The start script auto-generates .env with GPU detection — these are optional overrides.

# --- Docker Compose ---
# GPU override is auto-detected by ./krull start. Set manually if needed:
# COMPOSE_FILE=docker-compose.yml:docker-compose.gpu.yml

# --- Ollama ---
# Default model to pull with ./krull pull-model (no arguments)
# OLLAMA_MODEL=frob/qwen3.5-instruct:9b

# Context window size (tokens). Match your model's max context.
# OLLAMA_NUM_CTX=131072

# --- Model Parameters ---
# Applied when pulling models with ./krull pull-model.
# Temperature 0.8 balances creativity with coherence for voice/persona work.
# Lower (0.6-0.7) for coding, higher (0.9) for more varied prose.
# OLLAMA_TEMPERATURE=0.8
# OLLAMA_TOP_P=0.8
# OLLAMA_TOP_K=20
# OLLAMA_PRESENCE_PENALTY=1.5

# --- Context Management ---
# Token threshold for auto-compacting conversation history.
# Should be ~75% of OLLAMA_NUM_CTX.
# CONTEXT_COMPACT_LIMIT=98304

# --- Security ---
# Open WebUI secret key (used for session tokens). Generate a real one for production.
# WEBUI_SECRET_KEY=changeme-generate-a-real-key

# LiteLLM API key (used by Claude Code to authenticate with the gateway).
# LITELLM_MASTER_KEY=sk-local-dev-key

# --- Geocoding ---
# Restrict Photon geocoding data to a specific country (ISO 3166-1 alpha-2).
# Leave empty for worldwide coverage.
# PHOTON_COUNTRY_CODE=US

# --- FAA Charts ---
# FAA VFR Sectional Chart edition date (updated every 56 days).
# Check https://aeronav.faa.gov/visual/ for the current edition.
# FAA_EDITION=03-19-2026
